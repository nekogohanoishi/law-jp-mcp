{
  "name": "law-jp-mcp",
  "version": "0.1.0",
  "description": "LLM-optimized Japanese law MCP server powered by e-Gov Law API v2",
  "type": "module",
  "bin": {
    "law-jp-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "vercel-build": "next build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "japanese-law",
    "e-gov",
    "llm",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.2",
    "mcp-handler": "^1.0.7",
    "next": "^15.5.12",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
